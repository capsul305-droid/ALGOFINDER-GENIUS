import streamlit as st
import pandas as pd

st.set_page_config(page_title="AlgoFinder Genius Pro", layout="wide")
st.title("🚀 AlgoFinder Genius Pro")

# --- 1. Link Paito Cepat ---
st.link_button("🌐 Buka Situs Paito Warna Hongkong", "https://angkanet22.com/paito-warna-hongkong-pools/")

# --- 2. Sidebar Input ---
with st.sidebar:
    st.header("⚙️ Kontrol Aplikasi")
    data_input = st.text_area("Masukkan Data 4D (satu per baris):", height=200)
    if st.button("Proses Data"):
        st.session_state['data_paito'] = [line.strip() for line in data_input.split('\n') if len(line.strip()) == 4]
        st.success("Data diproses!")

# --- 3. Logika Analisis ---
if 'data_paito' in st.session_state and st.session_state['data_paito']:
    data = st.session_state['data_paito']
    df = pd.DataFrame(data, columns=['Full'])
    df['As'] = df['Full'].str[0].astype(int)
    df['Kop'] = df['Full'].str[1].astype(int)
    df['Kepala'] = df['Full'].str[2].astype(int)
    df['Ekor'] = df['Full'].str[3].astype(int)

    # --- Tampilan Dasbor ---
    st.subheader("🎯 Ringkasan Prediksi - 4 Posisi")
    cols = st.columns(4)
    posisi_list = ['As', 'Kop', 'Kepala', 'Ekor']
    
    for i, pos in enumerate(posisi_list):
        with cols[i]:
            # Membuat kotak estetik (Card)
            with st.container(border=True):
                st.markdown(f"### {pos}")
                terkuat = df[pos].value_counts().idxmax()
                st.metric(label="Angka Terkuat", value=terkuat)
                
                # Indikator Visual (ProgressBar)
                persen = float(df[pos].value_counts(normalize=True).max() * 100)
                st.progress(persen / 100, text=f"Kekuatan: {int(persen)}%")
                
                tren = "Naik 📈" if df[pos].iloc[-1] > df[pos].iloc[-2] else "Turun 📉"
                st.write(f"Tren: {tren}")

    # --- Tampilan Paito ---
    st.subheader("🎨 Paito Warna")
    def color_paito(val):
        colors = {'0':'#FFD1DC', '1':'#B2EBF2', '2':'#C8E6C9', '3':'#FFF9C4', '4':'#E1BEE7', '5':'#FFCCBC', '6':'#D7CCC8', '7':'#CFD8DC', '8':'#F8BBD0', '9':'#B3E5FC'}
        return f'background-color: {colors.get(str(val)[-1], "white")}'
    
    st.dataframe(df.style.applymap(color_paito, subset=['Full']), use_container_width=True)

else:
    st.info("Silakan masukkan data 4D di sidebar untuk memulai.")
