import streamlit as st
import pandas as pd
import requests
from bs4 import BeautifulSoup

# Pengaturan Layout
st.set_page_config(layout="wide", page_title="AlgoFinder Genius")

# 1. FITUR SCRAPING: Mengambil data dari web
@st.cache_data(ttl=3600)
def get_paito_data(url):
    # Contoh untuk situs paito (sesuaikan selector dengan target web Anda)
    response = requests.get(url)
    soup = BeautifulSoup(response.text, 'html.parser')
    table = soup.find('table') # Cari tabel pertama
    df = pd.read_html(str(table))[0]
    return df

# 2. FITUR ANALISIS: Deteksi Pola Naik/Turun/Datar
def analyze_patterns(df):
    # Mengambil kolom terakhir (asumsi kolom terakhir adalah Ekor/Result)
    data = df.iloc[:, -1].astype(int)
    patterns = []
    for i in range(1, len(data)):
        if data[i] > data[i-1]: patterns.append("Naik")
        elif data[i] < data[i-1]: patterns.append("Turun")
        else: patterns.append("Datar")
    return patterns

# 3. FITUR PREDIKSI: Hitung Angka Kuat & Cadangan
def get_prediction(df):
    data = df.iloc[:, -1].astype(int)
    freq = data.value_counts()
    kuat = freq.index[0] # Angka paling sering muncul
    cadangan = freq.index[1] if len(freq) > 1 else 0
    return kuat, cadangan

# --- TAMPILAN APLIKASI ---
st.title("🚀 AlgoFinder Genius")

url_paito = st.text_input("Masukkan URL Paito:", "https://example-paito-site.com")

if st.button("Jalankan Analisis"):
    try:
        df = get_paito_data(url_paito)
        st.subheader("Data Paito Terkini")
        st.dataframe(df.head(10))
        
        # Eksekusi Analisis
        pola = analyze_patterns(df)
        kuat, cadangan = get_prediction(df)
        
        col1, col2 = st.columns(2)
        with col1:
            st.metric("Pola Terakhir", pola[-1])
        with col2:
            st.success(f"Angka Kuat: {kuat}")
            st.warning(f"Angka Cadangan: {cadangan}")
            
    except Exception as e:
        st.error(f"Gagal mengambil data: {e}")
